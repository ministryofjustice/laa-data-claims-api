meta {
  name: Validator Testing
  type: http
  seq: 4
}

post {
  url: http://{{HOST}}/api/v1/bulk-submissions?userId=test&offices=0P322F
  body: multipartForm
  auth: inherit
}

params:query {
  userId: test
  offices: 0P322F
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:multipart-form {
  file: @file(/Users/ben.hobden/BulkClaimFiles/DSTEW-913.3_valid_file_regression copy.csv) @contentType(text/csv)
}

tests {
  if(res.status === 201){
    const body = res.getBody();
    bru.setEnvVar("SUBMISSION_ID", body.submission_ids[0]);
  }else{
    throw new Error("POST failed - cannont set SUBMISSION_ID");
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
