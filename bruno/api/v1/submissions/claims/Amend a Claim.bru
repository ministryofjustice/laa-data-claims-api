meta {
  name: Amend a Claim
  type: http
  seq: 4
}

patch {
  url: http://{{HOST}}/api/v1/submissions/:submission_id/claims/:claim_id
  body: json
  auth: inherit
}

params:path {
  claim_id: {{CLAIM_ID}}
  submission_id: {{SUBMISSION_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:json {
  {
    "client_forename": "Testy",
    "client_surname": "McTestFace",
    "amendment_user_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
    "amendment_requested_by": "PROVIDER",
    "amendment_reason_code": "CASE_REOPENED_REBILLED"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
