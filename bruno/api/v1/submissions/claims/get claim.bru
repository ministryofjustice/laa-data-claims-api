meta {
  name: get claim
  type: http
  seq: 2
}

get {
  url: http://{{HOST}}/api/v1/submissions/:submission_id/claims/:claim_id
  body: none
  auth: inherit
}

params:path {
  claim_id: {{CLAIM_ID}}
  submission_id: {{SUBMISSION_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
  timeout: 0
}
