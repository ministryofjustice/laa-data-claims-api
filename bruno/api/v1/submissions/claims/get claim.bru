meta {
  name: get claim
  type: http
  seq: 2
}

get {
  url: http://{{HOST}}/api/v1/submissions/:submission_id/claims/:claim_id
  body: none
  auth: inherit
}

params:path {
  claim_id: {{CLAIM_ID}}
  submission_id: {{SUBMISSION_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

tests {
  if(res.status === 200){
    const body = res.getBody();
    bru.setEnvVar("SUMMARY_FEE_ID", body.fee_calculation_response.claim_summary_fee_id);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
