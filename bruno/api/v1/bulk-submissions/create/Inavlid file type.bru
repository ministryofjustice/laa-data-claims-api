meta {
  name: Inavlid file type
  type: http
  seq: 1
}

post {
  url: http://{{HOST}}/api/v1/bulk-submissions?userId=test&offices=moj
  body: multipartForm
  auth: inherit
}

params:query {
  userId: test
  offices: moj
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:multipart-form {
  file: @file(../claims-data/service/src/integrationTest/resources/test_upload_files/invalid/unsupported.doc)
}

settings {
  encodeUrl: true
  timeout: 0
}
