meta {
  name: txt file
  type: http
  seq: 1
}

post {
  url: http://{{HOST}}/api/v1/bulk-submissions?userId=test&offices=0U099L
  body: multipartForm
  auth: inherit
}

params:query {
  userId: test
  offices: 0U099L
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:multipart-form {
  file: @file(../claims-data/service/src/integrationTest/resources/test_upload_files/txt/outcomes_with_matter_starts.txt)
}

settings {
  encodeUrl: true
  timeout: 0
}
