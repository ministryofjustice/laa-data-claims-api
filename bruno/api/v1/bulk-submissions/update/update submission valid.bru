meta {
  name: update submission valid
  type: http
  seq: 3
}

patch {
  url: http://{{HOST}}/api/v1/bulk-submissions/:bulksubmission_id
  body: json
  auth: inherit
}

params:path {
  bulksubmission_id: {{BULKSUBMISSION_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:json {
  {
    "bulk_submission_id": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
    "status": "READY_FOR_PARSING",
    "error_code": "P100",
    "error_description": "string",
    "updated_by_user_id": "string"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
