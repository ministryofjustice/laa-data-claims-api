meta {
  name: Assement
  type: http
  seq: 1
}

get {
  url: http://{{HOST}}/api/v1/claims/:claim_id/assessments/:assessment_id
  body: none
  auth: inherit
}

params:path {
  assessment_id: {{ASSESSMENT_ID}}
  claim_id: {{CLAIM_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
  timeout: 0
}
