meta {
  name: Mark Claim Amendment Invalid
  type: http
  seq: 13
}

post {
  url: http://{{HOST}}/api/v1/claims/:claim_id/amendments/:amendment_id/invalid
  body: '{
    "updatedByUserId": "test-user"
  }'
  contentType: application/json
  auth: inherit
}

params:path {
  claim_id: {{CLAIM_ID}}
  amendment_id: {{AMENDMENT_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
  timeout: 0
}

