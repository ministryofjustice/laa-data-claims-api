meta {
  name: messages for submission
  type: http
  seq: 2
}

get {
  url: http://{{HOST}}/api/v1/validation-messages?submission-id={{SUBMISSION_ID}}
  body: none
  auth: inherit
}

params:query {
  submission-id: {{SUBMISSION_ID}}
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

settings {
  encodeUrl: true
  timeout: 0
}
