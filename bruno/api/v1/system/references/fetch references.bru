meta {
  name: fetch references
  type: http
  seq: 2
}

get {
  url: http://{{HOST}}/api/v1/system/references/amendment-requested-by
  body: multipartForm
  auth: inherit
}

headers {
  Authorization: {{AUTH_TOKEN}}
}

body:multipart-form {
